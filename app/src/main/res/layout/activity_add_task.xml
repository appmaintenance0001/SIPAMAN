<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F6FA">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#173A6A"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tambah Task"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 🔥 WAJIB: SATU CHILD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 🔥 SHIMMER -->
            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimmerLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="#DDDDDD"
                        android:layout_marginBottom="10dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="#DDDDDD"
                        android:layout_marginBottom="10dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:background="#DDDDDD"
                        android:layout_marginBottom="10dp"/>

                </LinearLayout>
            </com.facebook.shimmer.ShimmerFrameLayout>

            <!-- 🔥 FORM -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- CARD -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp">

                    <!-- JUDUL -->
                    <TextView
                        style="@style/label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1. Judul Task *"/>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/inputBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etJudul"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_judul"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- PROJECT -->
                    <TextView
                        style="@style/label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2. Project *"/>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/inputBoxDropdown"
                        app:startIconDrawable="@drawable/ic_building"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <AutoCompleteTextView
                            android:id="@+id/spProject"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_project"
                            android:focusable="false"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- JENIS -->
                    <TextView
                        style="@style/label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3. Jenis Maintenance *"/>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/inputBoxDropdown"
                        app:startIconDrawable="@drawable/ic_tools"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <AutoCompleteTextView
                            android:id="@+id/spJenis"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_jenis"
                            android:focusable="false"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- PIC -->
                    <TextView
                        style="@style/label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4. PIC / Teknisi *"/>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/inputBox"
                        app:startIconDrawable="@drawable/ic_user"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <AutoCompleteTextView
                            android:id="@+id/spPic"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_pic"
                            android:inputType="text"
                            android:completionThreshold="1"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- PRIORITY -->
                    <TextView
                        style="@style/label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5. Priority *"/>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/inputBoxDropdown"
                        app:startIconDrawable="@drawable/ic_flag"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <AutoCompleteTextView
                            android:id="@+id/spPriority"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_priority"
                            android:focusable="false"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- MULAI -->
                    <TextView
                        style="@style/label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="6. Tanggal Mulai *"/>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/inputBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <EditText
                            android:id="@+id/etMulai"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_mulai"
                            android:focusable="false"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- DUE -->
                    <TextView
                        style="@style/label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7. Due Date *"/>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/inputBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <EditText
                            android:id="@+id/etDue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/hint_due"
                            android:focusable="false"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- DESKRIPSI -->
                    <TextView
                        style="@style/label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8. Deskripsi *"/>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/inputBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDeskripsi"
                            android:layout_width="match_parent"
                            android:layout_height="120dp"
                            android:hint="@string/hint_deskripsi"
                            android:gravity="top"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- BEFORE -->
                    <TextView
                        style="@style/label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="9. Foto Before *"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvBefore"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <Button
                        android:id="@+id/btnAddBefore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tambah Before"/>

                    <!-- AFTER -->
                    <TextView
                        style="@style/label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10. Foto After *"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvAfter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:alpha="0.5"/>

                    <Button
                        android:id="@+id/btnAddAfter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tambah After"
                        android:visibility="gone"/>

                    <!-- SIMPAN -->
                    <Button
                        android:id="@+id/btnSimpan"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Simpan Task"
                        android:backgroundTint="#173A6A"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="16dp"/>

                    <ProgressBar
                        android:id="@+id/progressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/txtProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Uploading..."
                        android:visibility="gone"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>