<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Theme utama -->
    <style name="Theme.SIPAMAN" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash Theme -->
    <style name="Theme.SIPAMAN.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo_sipaman</item>
        <item name="postSplashScreenTheme">@style/Theme.SIPAMAN</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/splash_bg</item>
    </style>

</resources>